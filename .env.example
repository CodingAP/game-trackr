MOBYGAMES_API_KEY=your_mobygames_api_key_here
# Optional: refresh cached MobyGames info after this many hours (default: 168 = 7 days)
MOBYGAMES_CACHE_TTL_HOURS=168

# Required for create/edit/delete game journals (sign-in password)
ADMIN_PASSWORD=your_admin_password_here
# Optional: separate secret for signing auth tokens (defaults to a hash of ADMIN_PASSWORD)
# AUTH_TOKEN_SECRET=change_me_to_a_long_random_string
